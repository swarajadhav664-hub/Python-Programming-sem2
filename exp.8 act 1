balance = 5000

try:
    amount = float(input("Enter withdrawal amount: "))
    if amount > balance:
        raise ValueError("Insufficient balance!")
    balance -= amount
    print("Withdrawal successful. Remaining balance:", balance)
except ValueError as e:
    print("Error:", e) 
